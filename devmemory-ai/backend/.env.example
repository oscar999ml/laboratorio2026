# ============================================
# DevMemory AI - Environment Configuration
# ============================================
# Copia este archivo a .env y edita los valores
# IMPORTANTE: .env NO debe estar en git
# Ver: PRIVATE_CONFIG.md para más información
# ============================================

# SERVER
PORT=3000
NODE_ENV=development

# DATABASE
DB_PATH=./memory.db

# OPENAI API (Fase 2 - Descomentar cuando tengas API key)
# Obtén la key en: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT=30000

# OLLAMA (Fase 3 - Alternativa local y gratuita)
# Descomentar si usas Ollama en lugar de OpenAI
# OLLAMA_API_URL=http://localhost:11434
# OLLAMA_MODEL=mistral

# LOGGING
LOG_LEVEL=info
# DEBUG=devmemory:*

# EXTENSION
# HOST_EXTENSION=http://localhost:3000